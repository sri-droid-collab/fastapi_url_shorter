                    "hostPort": 8000,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "MONGODB_USERNAME",
                    "value": "srimurugansoftsuave_db_user"
                },
                {
                    "name": "MONGODB_PASSWORD",
                    "value": "Qmakqbk4QyDDpobA"
                },
                {
                    "name": "MONGODB_HOSTNAME",
                    "value": "url-shorter.1v0e60n.mongodb.net/?appName=url-shorter"
                },
                {
                    "name": "MONGODB_DATABASE_NAME",
                    "value": "url_shortener"
